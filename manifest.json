{
   "manifest_version": 3,
   "name": "Motivation Counter",
   "version": "1.1.1",
   "description": "Replace new tab with a real-time motivation counter: track your age, countdown to a date, or to the end of the year.",
   "author": "Igor Pershin <igor.pershin.me@gmail.com>",
   "homepage_url": "https://github.com/1gory/motivation-age-counter-extension",
   "chrome_url_overrides": {
      "newtab": "dashboard.html"
   },
   "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
   },
   "action": {
      "default_title": "Motivation Counter",
      "default_icon": {
         "16": "icons/icon16.png",
         "32": "icons/icon32.png",
         "48": "icons/icon48.png",
         "128": "icons/icon128.png"
      }
   },
   "permissions": [],
   "host_permissions": [],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
   },
   "minimum_chrome_version": "88",
   "offline_enabled": true
}
